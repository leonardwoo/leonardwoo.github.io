---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { site } from '../../site.config';
import { t } from '../../i18n';
import { tagToSlug } from '../../utils/slug';
import { siteHref } from '../../utils/paths';
import { getBlogPosts } from '../../utils/posts';

export async function getStaticPaths() {
  const blogPosts = await getBlogPosts();
  const tagSet = new Set<string>();
  for (const post of blogPosts) {
    for (const tag of post.data.tags) tagSet.add(tag);
  }
  return [...tagSet].map((tag) => ({
    params: { tag: tagToSlug(tag) },
    props: {
      tag,
      posts: blogPosts.filter((p) => p.data.tags.includes(tag)),
    },
  }));
}

const { tag, posts } = Astro.props;
const i18n = t(site.language);
---

<BaseLayout title={`${i18n.pageTagPrefix}: ${tag}`} pageId="tag">
  <div class="tag-meta-info">
    <h1 class="page-list-title"># {tag}</h1>
    <p class="tag-count">{i18n.tagPostCount(posts.length)}</p>
    <a href={siteHref('/tags/')} class="button button-secondary button-small">← {i18n.allTags}</a>
  </div>
  <hr class="section-divider" />
  <div class="post-list">
    {posts.length === 0 ? (
      <p class="empty-state">{i18n.noPosts}</p>
    ) : (
      posts.map((post) => <PostCard post={post} />)
    )}
  </div>
</BaseLayout>
