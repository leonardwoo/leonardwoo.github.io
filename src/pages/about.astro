---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
import { t } from '../i18n';
import { absoluteUrl } from '../utils/paths';
import { getEntry, render } from 'astro:content';

const i18n = t(site.language);
const entry = await getEntry('pages', 'about');
if (!entry) throw new Error('Missing src/content/pages/about.md');
const { Content } = await render(entry);
const pageTitle = entry.data.title;
const canonicalUrl = absoluteUrl('/about/');
---

<BaseLayout
  title={i18n.pageAbout}
  description={entry.data.summary ?? site.description}
  pageId="about"
  canonicalUrl={canonicalUrl}
>
  <div class="page-header">
    <h1>{pageTitle}</h1>
  </div>
  <div class="post-content">
    <Content />
  </div>
</BaseLayout>
