---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { site } from '../../site.config';
import { t } from '../../i18n';
import { absoluteUrl, siteHref } from '../../utils/paths';
import { formatDate, getBlogPosts, postUrl } from '../../utils/posts';

const i18n = t(site.language);
const blogPosts = await getBlogPosts();
const recentPosts = blogPosts.slice(0, 5);
const rssUrl = absoluteUrl('/rss.xml');
const atomUrl = absoluteUrl('/atom.xml');
const canonicalUrl = absoluteUrl('/feed/');
---

<BaseLayout
  title={i18n.pageFeed}
  description={i18n.feedDescription}
  pageId="feed"
  canonicalUrl={canonicalUrl}
>
  <div class="feed-page">
    <h1>{i18n.pageFeed}</h1>
    <p class="feed-intro">{i18n.feedIntro}</p>

    <div class="feed-card">
      <p class="feed-label">{i18n.feedRssUrlLabel}</p>
      <p><a href={siteHref('/rss.xml')} class="feed-url">{rssUrl}</a></p>
      <p class="feed-label">{i18n.feedAtomUrlLabel}</p>
      <p><a href={siteHref('/atom.xml')} class="feed-url">{atomUrl}</a></p>
    </div>

    {recentPosts.length > 0 ? (
      <>
        <h2>{i18n.recentPosts}</h2>
        <ul class="feed-preview-list">
          {recentPosts.map((post) => (
            <li class="feed-preview-item">
              <span class="feed-preview-date">
                {formatDate(post.data.date, site.language)}
              </span>
              <a href={postUrl(post)}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </>
    ) : (
      <p class="empty-state">{i18n.noPosts}</p>
    )}
  </div>
</BaseLayout>
