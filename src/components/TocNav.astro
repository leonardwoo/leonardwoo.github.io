---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  class?: string;
}

const { headings, class: className } = Astro.props;
const items = headings.filter((h) => h.depth >= 1 && h.depth <= 4);

type TocNode = { heading: Heading; children: TocNode[] };

function buildTree(list: Heading[]): TocNode[] {
  const roots: TocNode[] = [];
  const stack: TocNode[] = [];
  for (const heading of list) {
    const node: TocNode = { heading, children: [] };
    while (stack.length > 0 && stack[stack.length - 1]!.heading.depth >= heading.depth) {
      stack.pop();
    }
    if (stack.length === 0) roots.push(node);
    else stack[stack.length - 1]!.children.push(node);
    stack.push(node);
  }
  return roots;
}

const tree = buildTree(items);
const hasToc = tree.length > 0;
---

{hasToc && (
  <div class={className}>
    <ul>
      {tree.map((node) => (
        <li>
          <a href={`#${node.heading.slug}`}>{node.heading.text}</a>
          {node.children.length > 0 && (
            <ul>
              {node.children.map((child) => (
                <li>
                  <a href={`#${child.heading.slug}`}>{child.heading.text}</a>
                  {child.children.length > 0 && (
                    <ul>
                      {child.children.map((grand) => (
                        <li>
                          <a href={`#${grand.heading.slug}`}>{grand.heading.text}</a>
                        </li>
                      ))}
                    </ul>
                  )}
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </div>
)}
